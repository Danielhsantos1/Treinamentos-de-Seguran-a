    return`<div class="li" onclick="abrirDetTrein('${t.id}')">
      <div class="av" style="background:${st==='valido'?'#dcfce7':st==='vencido'?'#fee2e2':'#fef3c7'}">${ico}</div>
      <div class="inf"><h3>${t.emp2Nome}</h3><p>${t.nome} · ${t.empNome||''}</p></div>
