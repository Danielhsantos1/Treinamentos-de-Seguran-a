<!-- Firebase -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, addDoc, doc, deleteDoc, updateDoc, onSnapshot,
         query, orderBy, serverTimestamp, where, getDocs, writeBatch }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword,
         signOut, onAuthStateChanged, sendPasswordResetEmail }
  from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

const cfg = {
  apiKey:"AIzaSyA54DFUohTR9W5uQpmbGq5gDq1vim7Jrfg",
  authDomain:"safetrack-c96ef.firebaseapp.com",
  projectId:"safetrack-c96ef",
  storageBucket:"safetrack-c96ef.firebasestorage.app",
  messagingSenderId:"1062220975476",
  appId:"1:1062220975476:web:f9372f588f9f8b768eb021"
};
const app  = initializeApp(cfg);
const db   = getFirestore(app);
const auth = getAuth(app);
window.db=db; window.auth=auth;
window.FS={ collection,addDoc,doc,deleteDoc,updateDoc,onSnapshot,
            query,orderBy,serverTimestamp,where,getDocs,writeBatch };
window.AU={ createUserWithEmailAndPassword,signInWithEmailAndPassword,
            signOut,onAuthStateChanged,sendPasswordResetEmail };

onAuthStateChanged(auth, u=>{
  window.USER=u;
  window.IS_ADMIN = u?.email===window.ADMIN_EMAIL;
  if(u){ showApp(); iniciarApp(); }
  else  { showLogin(); pararListeners(); }
});
</script>

<!-- Libs -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<style>
:root{
  --azul:#0f2744;--azul2:#1a4a8a;--verde:#15803d;--verm:#b91c1c;
  --amar:#d97706;--cinza:#f0f4f8;--txt:#1e293b;--sub:#64748b;
  --borda:#e2e8f0;--sombra:0 2px 12px rgba(0,0,0,.08);--r:12px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--cinza);color:var(--txt);min-height:100vh}

/* ── LOGIN ── */
#pg-login{display:flex;align-items:center;justify-content:center;min-height:100vh;
  background:linear-gradient(135deg,#071428,#0f2744,#1a4a8a);padding:20px}
.lcard{background:#fff;border-radius:20px;padding:32px 24px;width:100%;max-width:380px;box-shadow:0 12px 48px rgba(0,0,0,.35)}
.lcard .logo{text-align:center;margin-bottom:24px}
.lcard .logo .ico{font-size:52px}
.lcard .logo h1{font-size:22px;font-weight:800;color:var(--azul);margin-top:8px}
.lcard .logo p{font-size:13px;color:var(--sub)}
.ltab{display:flex;background:var(--cinza);border-radius:10px;padding:4px;gap:4px;margin-bottom:20px}
.ltab button{flex:1;padding:8px;border:none;background:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;color:var(--sub)}
.ltab button.on{background:#fff;color:var(--azul);box-shadow:0 1px 4px rgba(0,0,0,.1)}
.lmsg{border-radius:8px;padding:10px 12px;font-size:13px;margin-bottom:12px;display:none}
.lmsg.err{background:#fee2e2;color:#991b1b}
.lmsg.ok{background:#dcfce7;color:#166534}

/* ── APP ── */
#pg-app{display:none;max-width:480px;margin:0 auto;position:relative;min-height:100vh}

/* ── TOPBAR ── */
.topbar{background:var(--azul);color:#fff;padding:13px 16px 11px;position:sticky;top:0;z-index:100;display:flex;align-items:center;gap:10px}
.topbar h1{font-size:16px;font-weight:700;flex:1}
.topbar button{background:rgba(255,255,255,.15);border:none;color:#fff;width:34px;height:34px;border-radius:50%;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}

/* ── NAVBAR ── */
.navbar{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;
  background:#fff;border-top:1px solid var(--borda);display:flex;z-index:200;
  box-shadow:0 -2px 10px rgba(0,0,0,.07)}
.nb{flex:1;display:flex;flex-direction:column;align-items:center;padding:8px 2px 7px;gap:2px;
  border:none;background:none;cursor:pointer;color:var(--sub);font-size:9px;font-weight:600}
.nb.on{color:var(--azul2)}
.nb .ico{font-size:20px;line-height:1}

/* ── TELAS ── */
.tela{display:none;padding-bottom:80px;min-height:100vh}
.tela.on{display:block}

/* ── CARDS ── */
.card{background:#fff;border-radius:var(--r);box-shadow:var(--sombra);margin:12px 14px;overflow:hidden}
.card-body{padding:14px 16px}

/* ── HERO ── */
.hero{background:linear-gradient(135deg,var(--azul),var(--azul2));color:#fff;padding:18px 18px 28px;margin-bottom:-16px}
.hero h2{font-size:20px;font-weight:800}

/* ── STATS ── */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:16px 14px 0}
.stat{background:#fff;border-radius:10px;padding:12px 8px;text-align:center;box-shadow:var(--sombra);border-top:3px solid transparent}
.stat .n{font-size:24px;font-weight:800}
.stat .l{font-size:9px;color:var(--sub);font-weight:700;text-transform:uppercase;margin-top:2px}
.stat.az{border-color:var(--azul2)} .stat.az .n{color:var(--azul2)}
.stat.vd{border-color:var(--verde)} .stat.vd .n{color:var(--verde)}
.stat.vm{border-color:var(--verm)}  .stat.vm .n{color:var(--verm)}
.stat.am{border-color:var(--amar)}  .stat.am .n{color:var(--amar)}

/* ── LISTA ── */
.li{display:flex;align-items:center;gap:11px;padding:11px 14px;border-bottom:1px solid var(--borda);cursor:pointer;transition:background .15s}
.li:last-child{border-bottom:none}
.li:active{background:var(--cinza)}
.av{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;background:var(--cinza)}
.li .inf{flex:1;min-width:0}
.li .inf h3{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.li .inf p{font-size:11px;color:var(--sub);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ch{color:var(--sub);font-size:14px;flex-shrink:0}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;border-radius:20px;font-size:10px;font-weight:700;text-transform:uppercase;white-space:nowrap;flex-shrink:0}
.vd-b{background:#dcfce7;color:#166534}
.am-b{background:#fef3c7;color:#92400e}
.vm-b{background:#fee2e2;color:#991b1b}
.az-b{background:#dbeafe;color:#1e40af}

/* ── FORM ── */
.fg{margin-bottom:13px}
.fg label{display:block;font-size:11px;font-weight:700;color:var(--sub);margin-bottom:5px;text-transform:uppercase;letter-spacing:.4px}
.fg input,.fg select,.fg textarea{width:100%;padding:11px 12px;border:1.5px solid var(--borda);border-radius:8px;font-size:14px;font-family:inherit;color:var(--txt);background:#fff;outline:none;transition:border-color .2s}
.fg input:focus,.fg select:focus{border-color:var(--azul2)}
.fg input.err{border-color:var(--verm)}
.ferr{font-size:11px;color:var(--verm);margin-top:3px;display:none}

/* ── BTNS ── */
.btn{display:flex;align-items:center;justify-content:center;gap:7px;padding:13px 18px;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;width:100%;font-family:inherit;margin-bottom:9px;transition:opacity .2s}
.btn:active{opacity:.82}
.btn-az{background:var(--azul2);color:#fff}
.btn-vd{background:var(--verde);color:#fff}
.btn-vm{background:var(--verm);color:#fff}
.btn-ol{background:transparent;border:2px solid var(--azul2);color:var(--azul2)}
.btn-gr{background:#f1f5f9;color:var(--txt);border:1.5px solid var(--borda)}
.btn-gold{background:linear-gradient(135deg,#b7860b,#d4a017);color:#fff}
.btn-sm{padding:7px 14px;font-size:12px;border-radius:8px;margin-bottom:0;width:auto}

/* ── FAB ── */
.fab{position:fixed;bottom:84px;right:18px;width:52px;height:52px;border-radius:50%;background:var(--azul2);color:#fff;border:none;font-size:24px;box-shadow:0 4px 16px rgba(26,74,138,.4);cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:150}

/* ── MODAL ── */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;align-items:flex-end}
.ov.on{display:flex}
.modal{background:#fff;border-radius:20px 20px 0 0;padding:20px;width:100%;max-height:93vh;overflow-y:auto;animation:su .25s ease}
@keyframes su{from{transform:translateY(100%)}to{transform:translateY(0)}}
.mh{width:40px;height:4px;background:var(--borda);border-radius:2px;margin:0 auto 14px}
.modal h2{font-size:16px;font-weight:800;margin-bottom:14px}

/* ── CHIPS ── */
.chips{display:flex;gap:7px;flex-wrap:nowrap;overflow-x:auto;padding:8px 14px;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{padding:5px 13px;border-radius:20px;border:1.5px solid var(--borda);background:#fff;font-size:11px;font-weight:700;cursor:pointer;color:var(--sub);white-space:nowrap;flex-shrink:0}
.chip.on{border-color:var(--azul2);background:var(--azul2);color:#fff}

/* ── MISC ── */
.sec{padding:13px 14px 7px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--sub)}
.notif{display:flex;gap:11px;padding:11px 14px;border-bottom:1px solid var(--borda);cursor:pointer}
.notif:active{background:var(--cinza)}
.dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:3px}
.dot.v{background:var(--verm)}.dot.a{background:var(--amar)}.dot.g{background:var(--verde)}
.empty{text-align:center;padding:36px 20px;color:var(--sub)}
.empty .ico{font-size:40px;margin-bottom:8px}
.loading{text-align:center;padding:28px;color:var(--sub);font-size:13px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:13px}
.tile{background:var(--cinza);border-radius:8px;padding:10px 11px}
.tile .r{font-size:10px;color:var(--sub);font-weight:700;text-transform:uppercase}
.tile .v{font-weight:700;margin-top:3px;font-size:13px;word-break:break-word}
.vb{background:#f0fdf4;border:1.5px solid #bbf7d0;border-radius:8px;padding:10px;margin-bottom:13px;display:none}
.vb p{font-size:12px;color:#166534;font-weight:600}
.vb .vd{font-size:17px;font-weight:800;color:var(--verde);margin-top:3px}
.emp-tag{display:inline-flex;align-items:center;gap:4px;background:#dbeafe;color:#1e40af;padding:3px 8px;border-radius:6px;font-size:11px;font-weight:700}
.ph{background:linear-gradient(135deg,var(--azul),var(--azul2));padding:20px 16px;color:#fff;text-align:center}
.ph .abig{width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.18);border:3px solid rgba(255,255,255,.4);margin:0 auto 9px;display:flex;align-items:center;justify-content:center;font-size:28px}
.cp{background:#fff;border-radius:var(--r);box-shadow:var(--sombra);margin:12px 14px;overflow:hidden}
.cp canvas{width:100%!important;height:auto!important;display:block}
.sb{background:#eff6ff;border:1.5px solid #bfdbfe;border-radius:10px;padding:11px;margin-bottom:11px}
.slink{font-size:11px;color:#1e40af;word-break:break-all;background:#dbeafe;padding:6px;border-radius:6px;margin:5px 0 7px}
.tog{padding:5px 10px;border-radius:20px;border:1.5px solid var(--borda);background:#fff;font-size:11px;font-weight:700;cursor:pointer}
.tog.p{border-color:var(--verde);background:#dcfce7;color:#166534}
.tog.a{border-color:var(--verm);background:#fee2e2;color:#991b1b}
.tog.j{border-color:var(--amar);background:#fef3c7;color:#92400e}

/* ── MATRIZ ── */
.matriz-wrap{overflow-x:auto;margin:0 14px 14px}
.matriz-table{border-collapse:collapse;width:100%;font-size:12px;min-width:500px}
.matriz-table th{background:var(--azul);color:#fff;padding:8px 10px;text-align:left;font-size:11px;white-space:nowrap}
.matriz-table td{padding:8px 10px;border-bottom:1px solid var(--borda);vertical-align:middle}
.matriz-table tr:nth-child(even) td{background:#f8fafc}
.status-icon{font-size:14px}

/* ── IMPORT ── */
.drop-area{border:2px dashed var(--borda);border-radius:12px;padding:30px 20px;text-align:center;cursor:pointer;transition:border-color .2s;margin-bottom:13px}
.drop-area:hover,.drop-area.drag{border-color:var(--azul2);background:#eff6ff}
.drop-area .ico{font-size:36px;margin-bottom:8px}
.drop-area p{font-size:13px;color:var(--sub)}

/* ── QR SCANNER ── */
#qr-wrap{border-radius:14px;overflow:hidden;margin:14px;background:#000;min-height:260px;position:relative}
#html5-qrcode-button-camera-permission,#html5-qrcode-button-camera-stop{
  background:var(--azul2)!important;color:#fff!important;border:none!important;
  padding:9px 18px!important;border-radius:8px!important;font-weight:700!important;cursor:pointer!important;margin:8px!important}
#html5-qrcode-anchor-scan-type-change{display:none!important}

/* ── FILTROS ── */
.filter-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:8px 14px}
.filter-row select,.filter-row input{padding:9px 10px;border:1.5px solid var(--borda);border-radius:8px;font-size:12px;font-family:inherit;outline:none;width:100%}

/* ── CHARTS ── */
.chart-wrap{padding:0 14px 14px}
.chart-box{background:#fff;border-radius:var(--r);padding:14px;box-shadow:var(--sombra);margin-bottom:12px}
.chart-box h3{font-size:13px;font-weight:700;color:var(--azul);margin-bottom:10px}

#toast{display:none;position:fixed;bottom:88px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:10px 16px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;white-space:nowrap;box-shadow:0 4px 16px rgba(0,0,0,.3);max-width:90vw;text-align:center}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--borda);border-radius:4px}
</style>
</head>
<body>

<!-- CONFIG -->
<script>window.ADMIN_EMAIL = "admin@safetrack.com.br";</script>

<!-- ══════════ LOGIN ══════════ -->
<div id="pg-login">
<div class="lcard">
  <div class="logo">
    <div class="ico">🦺</div>
    <h1>SafeTrack</h1>
    <p>Gestão de Treinamentos de Segurança</p>
  </div>
  <div class="ltab">
    <button class="on" id="lt-in"  onclick="ltab('in')">Entrar</button>
    <button          id="lt-reg" onclick="ltab('reg')">Criar conta</button>
  </div>
  <div id="lmsg" class="lmsg"></div>
  <div id="pp-in">
    <div class="fg"><label>E-mail</label><input id="l-em" type="email" placeholder="seu@email.com" onkeydown="if(event.key==='Enter')login()"></div>
    <div class="fg"><label>Senha</label><input id="l-pw" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')login()">
      <div style="text-align:right;margin-top:5px"><a style="font-size:12px;color:var(--azul2);cursor:pointer" onclick="resetPw()">Esqueci minha senha</a></div>
    </div>
    <button class="btn btn-az" onclick="login()">Entrar →</button>
  </div>
  <div id="pp-reg" style="display:none">
    <div class="fg"><label>Nome *</label><input id="r-nm" type="text" placeholder="Seu nome"></div>
    <div class="fg"><label>E-mail *</label><input id="r-em" type="email" placeholder="seu@email.com"></div>
    <div class="fg"><label>Senha * (mín. 6 dígitos)</label><input id="r-pw" type="password" placeholder="••••••••"></div>
    <button class="btn btn-vd" onclick="register()">Criar conta →</button>
  </div>
</div>
</div>

<!-- ══════════ APP ══════════ -->
<div id="pg-app">

<!-- DASHBOARD -->
<div class="tela on" id="t-dash">
  <div class="hero">
    <div style="font-size:11px;opacity:.6;font-weight:700;letter-spacing:.5px;margin-bottom:3px">BOM DIA 👋</div>
    <h2>SafeTrack</h2>
    <p style="font-size:12px;opacity:.7;margin-top:2px" id="ue-label"></p>
    <span id="admin-badge" class="badge az-b" style="display:none;margin-top:5px">👑 ADMIN</span>
  </div>

  <!-- Stats principais -->
  <div class="stats" id="dash-stats">
    <div class="stat az"><div class="n" id="ds-emp">—</div><div class="l">Empresas</div></div>
    <div class="stat az"><div class="n" id="ds-emp2">—</div><div class="l">Empregados</div></div>
    <div class="stat az"><div class="n" id="ds-trein">—</div><div class="l">Treinamentos</div></div>
    <div class="stat vd"><div class="n" id="ds-vd">—</div><div class="l">Vigentes</div></div>
    <div class="stat am"><div class="n" id="ds-am">—</div><div class="l">A Vencer</div></div>
    <div class="stat vm"><div class="n" id="ds-vm">—</div><div class="l">Vencidos</div></div>
  </div>

  <!-- Gráficos -->
  <div class="chart-wrap" style="margin-top:16px">
    <div class="chart-box">
      <h3>📊 Status dos Treinamentos</h3>
      <canvas id="chart-status" height="160"></canvas>
    </div>
    <div class="chart-box">
      <h3>🏢 Treinamentos por Empresa</h3>
      <canvas id="chart-emp" height="180"></canvas>
    </div>
    <div class="chart-box">
      <h3>📅 Vencimentos por Mês</h3>
      <canvas id="chart-mes" height="160"></canvas>
    </div>
  </div>

  <!-- Alertas -->
  <div class="sec">⚠️ Alertas</div>
  <div class="card" style="margin-top:0" id="dash-alertas"><div class="loading">⏳ Carregando…</div></div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:9px;padding:0 14px 8px;margin-top:4px">
    <button class="btn btn-az" style="margin:0" onclick="ir('t-emp')">🏢 Empresas</button>
    <button class="btn btn-az" style="margin:0;background:#1a5c8a" onclick="ir('t-emp2')">👷 Empregados</button>
    <button class="btn btn-vd" style="margin:0" onclick="ir('t-trein')">🎓 Treinamentos</button>
    <button class="btn btn-ol" style="margin:0" onclick="ir('t-import')">📥 Importar Excel</button>
  </div>
  <div style="padding:0 14px 20px;margin-top:4px">
    <button class="btn btn-gr" style="margin:0" onclick="logout()">🚪 Sair da conta</button>
  </div>
</div>

<!-- EMPRESAS -->
<div class="tela" id="t-emp">
  <div class="topbar">
    <button onclick="ir('t-dash')" style="font-size:18px">‹</button>
    <h1>🏢 Empresas</h1>
    <button onclick="abrir('m-emp')">＋</button>
  </div>
  <div style="padding:11px 14px">
    <input type="search" id="busca-emp" placeholder="🔍  Buscar empresa…" oninput="filtrarEmp()"
      style="width:100%;padding:10px 12px;border:1.5px solid var(--borda);border-radius:10px;font-size:13px;font-family:inherit;outline:none">
  </div>
  <div class="card" id="lista-emp" style="margin-top:0"><div class="loading">⏳ Carregando…</div></div>
  <button class="fab" onclick="abrir('m-emp')">＋</button>
</div>

<!-- EMPREGADOS -->
<div class="tela" id="t-emp2">
  <div class="topbar">
    <button onclick="ir('t-dash')" style="font-size:18px">‹</button>
    <h1>👷 Empregados</h1>
    <button onclick="abrir('m-emp2')">＋</button>
  </div>
  <div class="filter-row">
    <input type="search" id="busca-emp2" placeholder="🔍  Nome ou CPF…" oninput="filtrarEmp2()"
      style="grid-column:1/-1;padding:10px 12px;border:1.5px solid var(--borda);border-radius:10px;font-size:13px;font-family:inherit;outline:none">
    <select id="fil-emp-emp2" onchange="filtrarEmp2()"><option value="">Todas as empresas</option></select>
    <select id="fil-status-emp2" onchange="filtrarEmp2()">
      <option value="">Todos os status</option>
      <option value="vencido">❌ Vencido</option>
      <option value="vencer">⚠️ A vencer</option>
      <option value="valido">✅ Vigente</option>
    </select>
  </div>
  <div class="card" id="lista-emp2" style="margin-top:0"><div class="loading">⏳ Carregando…</div></div>
