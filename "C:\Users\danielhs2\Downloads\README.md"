<script>
// ── CONFIG ───────────────────────────────────────────────
const CURSOS_VALIDADE = {
  'NR-35 – TRABALHO EM ALTURA':24,'NR-10 – SEGURANÇA ELÉTRICA':24,
  'NR-33 – ESPAÇO CONFINADO':12,'NR-12 – MÁQUINAS E EQUIPAMENTOS':24,
  'NR-20 – INFLAMÁVEIS E COMBUSTÍVEIS':12,'NR-06 – EPI':12,
  'CIPA – NR-05':12,'PRIMEIROS SOCORROS':24,'NR-18 – CONSTRUÇÃO CIVIL':12
};

// ── ESTADO ───────────────────────────────────────────────
let empresas=[], emp2s=[], treins=[];
let _uns=[], chartStatus=null, chartEmp=null, chartMes=null;
let xlDados=null, perfilAtual=null, treinAtual=null, empAtual=null;
let filtroTreinChip='todos';

// ── MÁSCARAS ─────────────────────────────────────────────
function mCPF(i){let v=i.value.replace(/\D/g,'').slice(0,11);v=v.replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d{1,2})$/,'$1-$2');i.value=v;}
function mCNPJ(i){let v=i.value.replace(/\D/g,'').slice(0,14);v=v.replace(/(\d{2})(\d)/,'$1.$2').replace(/(\d{3})(\d)/,'$1.$2').replace(/(\d{3})(\d)/,'$1/$2').replace(/(\d{4})(\d{1,2})$/,'$1-$2');i.value=v;}
function mTel(i){let v=i.value.replace(/\D/g,'').slice(0,11);v=v.length<=10?v.replace(/(\d{2})(\d{4})(\d{0,4})/,'($1) $2-$3'):v.replace(/(\d{2})(\d{5})(\d{0,4})/,'($1) $2-$3');i.value=v.trim().replace(/-$/,'');}
const vCPF=v=>/^\d{3}\.\d{3}\.\d{3}-\d{2}$/.test(v);
const vCNPJ=v=>/^\d{2}\.\d{3}\.\d{3}\/\d{4}-\d{2}$/.test(v);
const vEmail=v=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);

// ── HELPERS DATA ─────────────────────────────────────────
function calcSt(v){
  if(!v)return'valido';
  const h=new Date();h.setHours(0,0,0,0);
  const d=Math.round((new Date(v+'T00:00:00')-h)/86400000);
  return d<0?'vencido':d<=30?'vencer':d<=90?'alerta':'valido';
}
function dias(v){if(!v)return null;const h=new Date();h.setHours(0,0,0,0);return Math.round((new Date(v+'T00:00:00')-h)/86400000);}
function fmtD(s){if(!s)return'—';const[y,m,d]=s.split('-');return`${d}/${m}/${y}`;}
function uid(){return window.USER?.uid||'';}
function badgeSt(st,d){
  if(st==='valido')return`<span class="badge vd-b">🟢 VIGENTE</span>`;
  if(st==='vencido')return`<span class="badge vm-b">🔴 VENCIDO</span>`;
  if(st==='alerta')return`<span class="badge am-b">🟡 VENCE EM ${d} DIAS</span>`;
  return`<span class="badge am-b">🟡 VENCE EM ${d} DIAS</span>`;
}
function stIcon(st){return st==='valido'?'🟢':st==='vencido'?'🔴':'🟡';}

// ── LOGIN ─────────────────────────────────────────────────
function showLogin(){document.getElementById('pg-login').style.display='flex';document.getElementById('pg-app').style.display='none';}
function showApp(){document.getElementById('pg-login').style.display='none';document.getElementById('pg-app').style.display='block';
  document.getElementById('ue-label').textContent=window.USER?.email||'';
  document.getElementById('admin-badge').style.display=window.IS_ADMIN?'inline-flex':'none';}
function ltab(t){
  document.getElementById('pp-in').style.display=t==='in'?'':'none';
  document.getElementById('pp-reg').style.display=t==='reg'?'':'none';
  document.getElementById('lt-in').classList.toggle('on',t==='in');
  document.getElementById('lt-reg').classList.toggle('on',t==='reg');
  lmsg('');
}
function lmsg(txt,tp=''){const el=document.getElementById('lmsg');el.textContent=txt;el.className='lmsg '+(tp||'');el.style.display=txt?'block':'none';}
const ERRS={'auth/invalid-credential':'E-mail ou senha incorretos.','auth/user-not-found':'Usuário não encontrado.','auth/wrong-password':'Senha incorreta.','auth/too-many-requests':'Muitas tentativas.','auth/email-already-in-use':'E-mail já cadastrado.','auth/weak-password':'Senha muito fraca.'};
async function login(){
  const em=document.getElementById('l-em').value.trim(),pw=document.getElementById('l-pw').value;
  if(!em||!pw){lmsg('Preencha e-mail e senha.','err');return;}
  if(!vEmail(em)){lmsg('E-mail inválido.','err');return;}
  try{await window.AU.signInWithEmailAndPassword(window.auth,em,pw);}
  catch(e){lmsg(ERRS[e.code]||'Erro ao entrar.','err');}
}
async function register(){
  const nm=document.getElementById('r-nm').value.trim(),em=document.getElementById('r-em').value.trim(),pw=document.getElementById('r-pw').value;
  if(!nm||!em||!pw){lmsg('Preencha todos os campos.','err');return;}
  if(!vEmail(em)){lmsg('E-mail inválido.','err');return;}
  if(pw.length<6){lmsg('Senha mínimo 6 caracteres.','err');return;}
  try{await window.AU.createUserWithEmailAndPassword(window.auth,em,pw);lmsg('Conta criada! Entrando…','ok');}
  catch(e){lmsg(ERRS[e.code]||'Erro.','err');}
}
async function resetPw(){
  const em=document.getElementById('l-em').value.trim();
  if(!em||!vEmail(em)){lmsg('Digite seu e-mail primeiro.','err');return;}
  await window.AU.sendPasswordResetEmail(window.auth,em);
  lmsg('E-mail de redefinição enviado!','ok');
}
async function logout(){pararScanner();await window.AU.signOut(window.auth);}

// ── NAV ──────────────────────────────────────────────────
function ir(id){
  if(id!=='t-qr')pararScanner();
  document.querySelectorAll('.tela').forEach(t=>t.classList.remove('on'));
  document.getElementById(id).classList.add('on');
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  const nb=document.getElementById('nb-'+id.replace('t-',''));
  if(nb)nb.classList.add('on');
  window.scrollTo(0,0);
  if(id==='t-qr')setTimeout(iniciarScanner,300);
  if(id==='t-matriz')renderMatriz();
}
function abrir(id){document.getElementById(id).classList.add('on');}
function fechar(id){document.getElementById(id).classList.remove('on');}
function toast(msg,err=false){
  const t=document.getElementById('toast');
  t.textContent=msg;t.style.background=err?'#b91c1c':'#1e293b';
  t.style.display='block';clearTimeout(t._t);
  t._t=setTimeout(()=>t.style.display='none',3200);
}
function ferr(id,show){const el=document.getElementById(id);if(el)el.style.display=show?'block':'none';}

// ── QUERY HELPER ─────────────────────────────────────────
function qry(col,order='criadoEm'){
  const{collection,query,orderBy,where}=window.FS,db=window.db;
  if(window.IS_ADMIN)return window.FS.query(collection(db,col),orderBy(order,'desc'));
  return window.FS.query(collection(db,col),where('userId','==',uid()),orderBy(order,'desc'));
}
function qryNome(col){
  const{collection,query,orderBy,where}=window.FS,db=window.db;
  if(window.IS_ADMIN)return window.FS.query(collection(db,col),orderBy('nome'));
  return window.FS.query(collection(db,col),where('userId','==',uid()),orderBy('nome'));
}
function qryRazao(col){
  const{collection,query,orderBy,where}=window.FS,db=window.db;
  if(window.IS_ADMIN)return window.FS.query(collection(db,col),orderBy('razaoSocial'));
  return window.FS.query(collection(db,col),where('userId','==',uid()),orderBy('razaoSocial'));
}
function pararListeners(){_uns.forEach(u=>u());_uns=[];}

// ── INICIAR APP ──────────────────────────────────────────
function iniciarApp(){
  pararListeners();
  _uns.push(window.FS.onSnapshot(qryRazao('empresas'),s=>{
    empresas=s.docs.map(d=>({id:d.id,...d.data()}));
    renderEmpresas();populaSelects();renderChips();
  }));
  _uns.push(window.FS.onSnapshot(qryNome('emp2s'),s=>{
    emp2s=s.docs.map(d=>({id:d.id,...d.data()}));
    renderEmp2s();populaSelectsEmp2();renderPresenca();
  }));
  _uns.push(window.FS.onSnapshot(qry('treins'),s=>{
    treins=s.docs.map(d=>({id:d.id,...d.data()}));
    renderTreins();renderDash();atualizarCharts();
  }));
  document.getElementById('t-real').value=new Date().toISOString().split('T')[0];
}

// ── DASHBOARD ────────────────────────────────────────────
function renderDash(){
  const vd=treins.filter(t=>['valido','alerta'].includes(calcSt(t.validade))).length;
  const am=treins.filter(t=>calcSt(t.validade)==='alerta').length;
  const vm=treins.filter(t=>calcSt(t.validade)==='vencido').length;
  const cpfs=new Set(emp2s.map(e=>e.cpf));
  document.getElementById('ds-emp').textContent=empresas.length;
  document.getElementById('ds-emp2').textContent=emp2s.length;
  document.getElementById('ds-trein').textContent=treins.length;
  document.getElementById('ds-vd').textContent=vd;
  document.getElementById('ds-am').textContent=am;
  document.getElementById('ds-vm').textContent=vm;

  // Alertas
  const urgentes=treins.filter(t=>{const s=calcSt(t.validade);return s==='vencido'||s==='alerta'||s==='vencer';})
    .sort((a,b)=>(dias(a.validade)||0)-(dias(b.validade)||0)).slice(0,10);
  const el=document.getElementById('dash-alertas');
  if(!urgentes.length){el.innerHTML=`<div class="empty"><div class="ico">🎉</div><p>Nenhum alerta!</p></div>`;return;}
  el.innerHTML=urgentes.map(t=>{
    const st=calcSt(t.validade),d=dias(t.validade);
    const msg=st==='vencido'?`Vencido há ${Math.abs(d)} dias`:d<=30?`Vence em ${d} dias`:`Vence em ${d} dias (atenção)`;
    return`<div class="notif" onclick="abrirDetTrein('${t.id}')">
      <div class="dot ${st==='vencido'?'v':'a'}"></div>
      <div style="flex:1"><strong style="font-size:13px">${t.emp2Nome} – ${t.nome}</strong>
      <p style="font-size:11px;color:var(--sub);margin-top:1px">${msg} · ${t.empNome||''}</p></div></div>`;
  }).join('');
}

// ── CHARTS ───────────────────────────────────────────────
function atualizarCharts(){
  // Status
  const vd=treins.filter(t=>calcSt(t.validade)==='valido').length;
  const am=treins.filter(t=>['vencer','alerta'].includes(calcSt(t.validade))).length;
  const vm=treins.filter(t=>calcSt(t.validade)==='vencido').length;

  if(chartStatus){chartStatus.data.datasets[0].data=[vd,am,vm];chartStatus.update();}
  else{
    const ctx=document.getElementById('chart-status').getContext('2d');
    chartStatus=new Chart(ctx,{type:'doughnut',data:{
      labels:['Vigentes','A Vencer','Vencidos'],
      datasets:[{data:[vd,am,vm],backgroundColor:['#15803d','#d97706','#b91c1c'],borderWidth:2}]
    },options:{responsive:true,plugins:{legend:{position:'bottom'}}}});
  }

  // Por empresa
  const empMap={};
  treins.forEach(t=>{const n=t.empNome||'Sem empresa';empMap[n]=(empMap[n]||0)+1;});
  const empLabels=Object.keys(empMap).slice(0,6),empVals=empLabels.map(k=>empMap[k]);
  if(chartEmp){chartEmp.data.labels=empLabels;chartEmp.data.datasets[0].data=empVals;chartEmp.update();}
  else{
    const ctx=document.getElementById('chart-emp').getContext('2d');
    chartEmp=new Chart(ctx,{type:'bar',data:{
      labels:empLabels,datasets:[{label:'Treinamentos',data:empVals,backgroundColor:'#1a4a8a',borderRadius:6}]
    },options:{responsive:true,indexAxis:'y',plugins:{legend:{display:false}},scales:{x:{grid:{display:false}}}}});
  }

  // Vencimentos por mês
  const mesMap={};
  treins.filter(t=>t.validade).forEach(t=>{
    const[y,m]=t.validade.split('-');const k=`${m}/${y}`;mesMap[k]=(mesMap[k]||0)+1;
  });
  const mesKeys=Object.keys(mesMap).sort((a,b)=>{const[ma,ya]=a.split('/');const[mb,yb]=b.split('/');return new Date(ya,ma-1)-new Date(yb,mb-1);}).slice(0,8);
  const mesVals=mesKeys.map(k=>mesMap[k]);
  if(chartMes){chartMes.data.labels=mesKeys;chartMes.data.datasets[0].data=mesVals;chartMes.update();}
  else{
    const ctx=document.getElementById('chart-mes').getContext('2d');
    chartMes=new Chart(ctx,{type:'line',data:{
      labels:mesKeys,datasets:[{label:'Vencimentos',data:mesVals,borderColor:'#d97706',backgroundColor:'rgba(217,119,6,.1)',fill:true,tension:.4}]
    },options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,grid:{color:'#f1f5f9'}}}}});
  }
}

