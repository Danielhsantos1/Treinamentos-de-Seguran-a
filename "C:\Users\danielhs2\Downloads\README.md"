// ── QR CODE SCANNER ───────────────────────────────────────
let qrCode=null,scanOn=false;
function iniciarScanner(){
  if(scanOn||document.getElementById('qr-scan-sec').style.display==='none')return;
  const wrap=document.getElementById('qr-wrap');
  wrap.innerHTML='<div id="qr-reader" style="width:100%"></div>';
  qrCode=new Html5Qrcode('qr-reader');
  qrCode.start({facingMode:'environment'},{fps:10,qrbox:{width:200,height:200}},txt=>{
    pararScanner();
    try{
      const url=new URL(txt);
      const id=url.searchParams.get('emp2');
      if(id){toast('QR lido! Carregando perfil…');setTimeout(()=>abrirPerfil(id),500);}
      else toast('QR Code lido: '+txt);
    }catch{toast('Conteúdo: '+txt);}
  },()=>{}).then(()=>scanOn=true)
    .catch(e=>{wrap.innerHTML=`<div style="color:#fff;padding:24px;text-align:center;font-size:13px">⚠️ Câmera indisponível.<br><small>${e}</small></div>`;});
}
function pararScanner(){if(qrCode&&scanOn){qrCode.stop().catch(()=>{});scanOn=false;}}
function modoQR(modo,chip){
  document.querySelectorAll('#t-qr .chips .chip').forEach(c=>c.classList.remove('on'));
  chip.classList.add('on');
  document.getElementById('qr-scan-sec').style.display=modo==='scan'?'':'none';
  document.getElementById('qr-gen-sec').style.display=modo==='gen'?'':'none';
  if(modo==='scan')setTimeout(iniciarScanner,200);else pararScanner();
}
function gerarQR(){
  const id=document.getElementById('sel-emp2-qr').value;
