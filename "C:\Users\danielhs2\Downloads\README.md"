<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NR Control · Gestão de Treinamentos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.4/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root{
  --bg:#12161A;
  --surface:#1A2027;
  --surface-2:#212933;
  --surface-3:#2A3340;
  --border:#313B47;
  --text:#EDEFF2;
  --text-dim:#93A0AC;
  --text-faint:#5C6773;
  --accent:#F2B705;
  --accent-dim:#8A6C0C;
  --steel:#4E8FBF;
  --green:#33C97A;
  --green-dim:#173824;
  --amber:#F2B705;
  --amber-dim:#3A2E08;
  --red:#EF5A5A;
  --red-dim:#3A1616;
  --radius:10px;
  --stripe:repeating-linear-gradient(135deg,var(--accent) 0 8px,#1a1a1a 8px 16px);
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Inter',sans-serif;
  -webkit-font-smoothing:antialiased;
  min-height:100vh;
}
h1,h2,h3,h4,.display{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:0.02em;
  margin:0;
}
.mono{font-family:'IBM Plex Mono',monospace;}
a{color:inherit;}
button{font-family:inherit;cursor:pointer;}
::selection{background:var(--accent);color:#14181C;}
::-webkit-scrollbar{width:10px;height:10px;}
::-webkit-scrollbar-track{background:var(--surface);}
::-webkit-scrollbar-thumb{background:var(--surface-3);border-radius:6px;}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}

/* ---- App shell ---- */
#app{display:flex;min-height:100vh;}

.sidebar{
  width:236px;flex-shrink:0;background:var(--surface);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  position:sticky;top:0;height:100vh;overflow-y:auto;
  z-index:40;
}
.brand{
  padding:22px 20px 18px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
}
.brand-mark{width:30px;height:30px;background:var(--stripe);border-radius:4px;flex-shrink:0;border:1px solid #000;}
.brand-text h1{font-size:20px;line-height:1;color:var(--text);}
.brand-text span{font-size:10px;letter-spacing:.14em;color:var(--text-dim);text-transform:uppercase;font-family:'IBM Plex Mono',monospace;}

nav.nav{padding:14px 10px;display:flex;flex-direction:column;gap:2px;flex:1;}
.nav-item{
  display:flex;align-items:center;gap:11px;padding:10px 12px;border-radius:7px;
  color:var(--text-dim);font-size:14px;font-weight:500;background:none;border:none;
  text-align:left;width:100%;border-left:3px solid transparent;transition:.12s;
}
.nav-item:hover{background:var(--surface-2);color:var(--text);}
.nav-item.active{background:var(--surface-2);color:var(--text);border-left:3px solid var(--accent);}
.nav-item .ic{width:18px;text-align:center;flex-shrink:0;}
.nav-count{margin-left:auto;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text-faint);}
.nav-sep{height:1px;background:var(--border);margin:10px 6px;}
.nav-label{font-size:10px;letter-spacing:.14em;color:var(--text-faint);text-transform:uppercase;padding:8px 12px 2px;font-family:'IBM Plex Mono',monospace;}

.role-box{padding:14px;border-top:1px solid var(--border);}
.role-select{
  width:100%;background:var(--surface-2);border:1px solid var(--border);color:var(--text);
  padding:9px 10px;border-radius:7px;font-size:12px;font-family:'IBM Plex Mono',monospace;
}

.main{flex:1;min-width:0;display:flex;flex-direction:column;}
.topbar{
  position:sticky;top:0;z-index:30;background:rgba(18,22,26,.9);backdrop-filter:blur(8px);
  border-bottom:1px solid var(--border);padding:16px 28px;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
}
.topbar h2{font-size:26px;color:var(--text);}
.topbar .sub{font-size:12.5px;color:var(--text-dim);font-family:'IBM Plex Mono',monospace;margin-top:2px;}
.search-box{
  display:flex;align-items:center;gap:8px;background:var(--surface-2);border:1px solid var(--border);
  border-radius:8px;padding:8px 12px;min-width:240px;
}
.search-box input{background:none;border:none;color:var(--text);font-size:13px;width:100%;outline:none;}
.search-box input::placeholder{color:var(--text-faint);}
.hamburger{display:none;background:var(--surface-2);border:1px solid var(--border);color:var(--text);border-radius:7px;padding:8px 10px;}

.content{padding:26px 28px 60px;flex:1;}

/* ---- Cards / grid ---- */
.kpi-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:22px;}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 16px 14px;position:relative;overflow:hidden;}
.kpi::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.kpi.k-total::before{background:var(--steel);}
.kpi.k-green::before{background:var(--green);}
.kpi.k-amber::before{background:var(--amber);}
.kpi.k-red::before{background:var(--red);}
.kpi .lbl{font-size:10.5px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.08em;font-family:'IBM Plex Mono',monospace;}
.kpi .val{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:34px;margin-top:6px;color:var(--text);}

.panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:18px 18px 14px;}
.panel + .panel{margin-top:16px;}
.panel-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.panel-head h3{font-size:16px;color:var(--text);}
.panel-head .hint{font-size:11px;color:var(--text-faint);font-family:'IBM Plex Mono',monospace;}

.charts-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.chart-box{height:230px;position:relative;}

/* ---- Buttons ---- */
.btn{
  display:inline-flex;align-items:center;gap:7px;padding:9px 15px;border-radius:7px;font-size:13px;font-weight:600;
  border:1px solid var(--border);background:var(--surface-2);color:var(--text);transition:.12s;
}
.btn:hover{background:var(--surface-3);}
.btn-primary{background:var(--accent);border-color:var(--accent);color:#14181C;}
.btn-primary:hover{background:#ffc61a;}
.btn-danger{background:var(--red-dim);border-color:var(--red);color:#ffb3b3;}
.btn-sm{padding:6px 10px;font-size:12px;}
.btn:disabled{opacity:.4;cursor:not-allowed;}

/* ---- Tables ---- */
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th{
  text-align:left;padding:10px 12px;color:var(--text-dim);font-size:10.5px;text-transform:uppercase;
  letter-spacing:.06em;font-family:'IBM Plex Mono',monospace;border-bottom:1px solid var(--border);
  white-space:nowrap;position:sticky;top:0;background:var(--surface);
}
td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:middle;}
tr:hover td{background:var(--surface-2);}
.row-btn{background:none;border:none;color:var(--text-dim);padding:4px 6px;border-radius:5px;}
.row-btn:hover{background:var(--surface-3);color:var(--text);}

/* ---- Badges / status ---- */
.badge{display:inline-flex;align-items:center;gap:6px;padding:3px 9px;border-radius:20px;font-size:11.5px;font-weight:600;font-family:'IBM Plex Mono',monospace;}
.badge.vigente{background:var(--green-dim);color:var(--green);}
.badge.vencendo{background:var(--amber-dim);color:var(--amber);}
.badge.vencido{background:var(--red-dim);color:var(--red);}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.dot.vigente{background:var(--green);}
.dot.vencendo{background:var(--amber);}
.dot.vencido{background:var(--red);}

/* ---- Filters ---- */
.filters{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;}
.filters select,.filters input{
  background:var(--surface-2);border:1px solid var(--border);color:var(--text);border-radius:7px;
  padding:8px 10px;font-size:12.5px;font-family:'Inter',sans-serif;
}
.filters .fg{display:flex;flex-direction:column;gap:4px;}
.filters label{font-size:10px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.06em;font-family:'IBM Plex Mono',monospace;}

/* ---- Cards list (empresas/empregados) ---- */
.grid-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;}
.co-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;cursor:pointer;transition:.12s;position:relative;}
.co-card:hover{border-color:var(--accent-dim);transform:translateY(-1px);}
.co-card h4{font-size:16px;color:var(--text);margin-bottom:10px;line-height:1.2;}
.co-stats{display:flex;gap:16px;margin-top:10px;}
.co-stat b{display:block;font-family:'Barlow Condensed',sans-serif;font-size:22px;color:var(--text);font-weight:700;}
.co-stat span{font-size:10px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.05em;font-family:'IBM Plex Mono',monospace;}

.emp-row{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;margin-bottom:8px;transition:.12s;}
.emp-row:hover{border-color:var(--accent-dim);}
.emp-avatar{width:36px;height:36px;border-radius:8px;background:var(--surface-3);display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-weight:700;color:var(--accent);flex-shrink:0;}
.emp-info{flex:1;min-width:0;}
.emp-info .nm{font-size:14.5px;font-weight:600;color:var(--text);}
.emp-info .meta{font-size:11.5px;color:var(--text-dim);font-family:'IBM Plex Mono',monospace;margin-top:1px;}
.emp-badges{display:flex;gap:6px;flex-shrink:0;}

/* ---- Modal ---- */
.overlay{position:fixed;inset:0;background:rgba(10,12,14,.72);backdrop-filter:blur(2px);z-index:100;display:flex;align-items:flex-start;justify-content:center;padding:40px 20px;overflow-y:auto;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:12px;width:100%;max-width:560px;padding:0;overflow:hidden;}
.modal-head{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--surface-2);}
.modal-head h3{font-size:18px;}
.modal-close{background:none;border:none;color:var(--text-dim);font-size:20px;line-height:1;padding:4px 8px;border-radius:6px;}
.modal-close:hover{background:var(--surface-3);color:var(--text);}
.modal-body{padding:20px 22px;max-height:70vh;overflow-y:auto;}
.modal-foot{padding:16px 22px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;background:var(--surface-2);}
.field{margin-bottom:14px;}
.field label{display:block;font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;font-family:'IBM Plex Mono',monospace;}
.field input,.field select{width:100%;background:var(--surface-2);border:1px solid var(--border);color:var(--text);padding:10px 11px;border-radius:7px;font-size:13.5px;}
.field-row{display:flex;gap:12px;}
.field-row .field{flex:1;}

/* ---- Alerts ---- */
.alert-item{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:8px;background:var(--surface-2);margin-bottom:8px;border-left:3px solid transparent;}
.alert-item.vencido{border-left-color:var(--red);}
.alert-item.vencendo{border-left-color:var(--amber);}
.alert-item.atencao{border-left-color:var(--steel);}
.alert-item .ai-name{font-weight:600;font-size:13.5px;}
.alert-item .ai-meta{font-size:11.5px;color:var(--text-dim);margin-top:2px;}
.alert-item .ai-days{margin-left:auto;font-family:'IBM Plex Mono',monospace;font-size:12px;text-align:right;flex-shrink:0;}

/* ---- Empty / loading ---- */
.empty-state{padding:60px 20px;text-align:center;color:var(--text-dim);}
.empty-state .ic{font-size:36px;margin-bottom:10px;opacity:.5;}
.empty-state h4{font-size:16px;color:var(--text);margin-bottom:6px;}
.empty-state p{font-size:13px;margin:0 auto;max-width:340px;line-height:1.5;}

/* ---- Import ---- */
.dropzone{border:2px dashed var(--border);border-radius:var(--radius);padding:40px 20px;text-align:center;background:var(--surface-2);cursor:pointer;transition:.15s;}
.dropzone:hover,.dropzone.drag{border-color:var(--accent);background:var(--surface-3);}
.dropzone input{display:none;}
.dropzone .ic{font-size:30px;margin-bottom:10px;}
.import-steps{display:flex;gap:0;margin-bottom:20px;}
.import-steps .step{flex:1;text-align:center;padding:10px;font-size:11px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.06em;font-family:'IBM Plex Mono',monospace;border-bottom:2px solid var(--border);}
.import-steps .step.active{color:var(--accent);border-bottom-color:var(--accent);}
.import-steps .step.done{color:var(--green);border-bottom-color:var(--green);}

/* ---- Pagination ---- */
.pagination{display:flex;align-items:center;justify-content:space-between;padding-top:14px;font-size:12px;color:var(--text-dim);}
.pagination .pg-btns{display:flex;gap:6px;}

/* ---- Public page ---- */
.pub-wrap{min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:40px 16px;background:radial-gradient(ellipse at top,#1b222a 0%,var(--bg) 60%);}
.pub-card{width:100%;max-width:480px;background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;}
.pub-strip{height:8px;background:var(--stripe);}
.pub-head{padding:26px 24px 18px;text-align:center;border-bottom:1px solid var(--border);}
.pub-head .pub-status{display:inline-block;margin-bottom:12px;}
.pub-head h2{font-size:28px;color:var(--text);}
.pub-head .cpf{font-family:'IBM Plex Mono',monospace;color:var(--text-dim);font-size:13px;margin-top:4px;}
.pub-head .co{font-size:12.5px;color:var(--steel);margin-top:6px;text-transform:uppercase;letter-spacing:.05em;font-family:'IBM Plex Mono',monospace;}
.pub-body{padding:18px 22px 22px;}
.pub-train{display:flex;align-items:center;gap:10px;padding:11px 4px;border-bottom:1px solid var(--border);}
.pub-train:last-child{border-bottom:none;}
.pub-train .pt-name{flex:1;font-size:13px;}
.pub-train .pt-date{font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--text-dim);}
.pub-foot{padding:14px 24px;text-align:center;font-size:10.5px;color:var(--text-faint);font-family:'IBM Plex Mono',monospace;border-top:1px solid var(--border);}

/* ---- QR block ---- */
.qr-block{display:flex;flex-direction:column;align-items:center;gap:12px;padding:18px;background:#fff;border-radius:10px;}
#qrcanvas-holder{display:flex;}

.consulta-shell{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;}
.consulta-box{max-width:420px;width:100%;text-align:center;}
.consulta-box .brand-mark{width:52px;height:52px;margin:0 auto 18px;border-radius:8px;}
.consulta-box h2{font-size:26px;margin-bottom:8px;}
.consulta-box p{color:var(--text-dim);font-size:13.5px;line-height:1.6;margin-bottom:22px;}

/* ---- Responsive ---- */
@media(max-width:1180px){
  .kpi-grid{grid-template-columns:repeat(3,1fr);}
  .charts-row{grid-template-columns:1fr;}
}
@media(max-width:900px){
  .sidebar{position:fixed;left:-260px;top:0;bottom:0;transition:left .2s;box-shadow:0 0 0 2000px rgba(0,0,0,0);}
  .sidebar.open{left:0;box-shadow:0 0 40px rgba(0,0,0,.5);}
  .hamburger{display:inline-flex;}
  .topbar h2{font-size:20px;}
  .content{padding:18px 16px 50px;}
  .kpi-grid{grid-template-columns:repeat(2,1fr);}
  .search-box{min-width:0;flex:1;}
}
@media(max-width:520px){
  .kpi-grid{grid-template-columns:1fr 1fr;}
  .field-row{flex-direction:column;}
}
</style>
</head>
<body>
<div id="app"></div>
<script>
