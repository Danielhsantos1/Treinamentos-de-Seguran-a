// ── CERTIFICADO PDF ──────────────────────────────────────
function desenharCert(canvas,d){
  const W=900,H=637;canvas.width=W;canvas.height=H;
  const c=canvas.getContext('2d');
  const bg=c.createLinearGradient(0,0,W,H);
  bg.addColorStop(0,'#0a1e3c');bg.addColorStop(.5,'#0f2744');bg.addColorStop(1,'#0a1e3c');
  c.fillStyle=bg;c.fillRect(0,0,W,H);
  c.strokeStyle='#c9a84c';c.lineWidth=6;c.strokeRect(18,18,W-36,H-36);
  c.lineWidth=1.5;c.strokeRect(28,28,W-56,H-56);
  [[28,28,0],[W-28,28,Math.PI/2],[W-28,H-28,Math.PI],[28,H-28,-Math.PI/2]].forEach(([x,y,r])=>{
    c.save();c.translate(x,y);c.rotate(r);c.strokeStyle='#c9a84c';c.lineWidth=2;
    [20,35,50].forEach(s=>{c.beginPath();c.moveTo(0,s);c.lineTo(0,0);c.lineTo(s,0);c.stroke();});c.restore();});
  c.save();c.translate(W/2,78);c.fillStyle='#c9a84c';c.beginPath();
  for(let i=0;i<12;i++){const r=(i*Math.PI)/6-Math.PI/2,ds=i%2===0?28:12;
    i===0?c.moveTo(Math.cos(r)*ds,Math.sin(r)*ds):c.lineTo(Math.cos(r)*ds,Math.sin(r)*ds);}
  c.closePath();c.fill();c.restore();
  const gL=()=>{const g=c.createLinearGradient(60,0,W-60,0);g.addColorStop(0,'transparent');g.addColorStop(.3,'#c9a84c');g.addColorStop(.7,'#c9a84c');g.addColorStop(1,'transparent');return g;};
  c.strokeStyle=gL();c.lineWidth=1.5;c.beginPath();c.moveTo(60,110);c.lineTo(W-60,110);c.stroke();
  c.textAlign='center';
  c.fillStyle='#c9a84c';c.font='bold 14px Georgia,serif';c.fillText('SAFETRACK – GESTÃO DE TREINAMENTOS',W/2,142);
  c.fillStyle='#fff';c.font='bold 50px Georgia,serif';c.fillText('CERTIFICADO',W/2,210);
  c.fillStyle='#c9a84c';c.font='19px Georgia,serif';c.fillText('DE CONCLUSÃO DE TREINAMENTO',W/2,240);
  c.strokeStyle=gL();c.lineWidth=1;c.beginPath();c.moveTo(100,260);c.lineTo(W-100,260);c.stroke();
  c.fillStyle='#cbd5e1';c.font='14px Georgia,serif';c.fillText('Certificamos que',W/2,292);
  c.fillStyle='#fff';c.font='bold 34px Georgia,serif';c.fillText((d.nome||'').toUpperCase(),W/2,342);
  const nW=c.measureText((d.nome||'').toUpperCase()).width;
  c.strokeStyle='#c9a84c';c.lineWidth=1.5;c.beginPath();c.moveTo(W/2-nW/2-20,352);c.lineTo(W/2+nW/2+20,352);c.stroke();
  const sub=[d.cargo,d.empresa].filter(Boolean).join(' · ');
  if(sub){c.fillStyle='#94a3b8';c.font='13px Georgia,serif';c.fillText(sub,W/2,375);}
  c.fillStyle='#cbd5e1';c.font='14px Georgia,serif';c.fillText('concluiu com aproveitamento o treinamento de',W/2,404);
  c.fillStyle='#fbbf24';c.font='bold 22px Georgia,serif';c.fillText((d.treinamento||'').toUpperCase(),W/2,438);
  if(d.ch){c.fillStyle='#94a3b8';c.font='13px Georgia,serif';c.fillText(`Carga Horária: ${d.ch}`,W/2,460);}
  c.strokeStyle=gL();c.lineWidth=1;c.beginPath();c.moveTo(60,480);c.lineTo(W-60,480);c.stroke();
  const c1=155,c2=W/2,c3=W-155;
  [[c1,'CPF',d.cpf||'—','#fff'],[c2,'DATA DE REALIZAÇÃO',fmtD(d.realizado),'#fff'],[c3,'VÁLIDO ATÉ',fmtD(d.validade),'#4ade80']].forEach(([x,rot,val,cor])=>{
    c.fillStyle='#c9a84c';c.font='bold 10px Georgia,serif';c.fillText(rot,x,505);
    c.fillStyle=cor;c.font='13px Georgia,serif';c.fillText(val,x,522);});
  c.fillStyle='#1e3a5f';c.font='bold 10px Georgia,serif';c.textAlign='right';c.fillText('safetrack.com.br',W-38,H-33);
  return canvas;
}

function getDadosCert(t){
  if(!t)return null;
  const a=emp2s.find(x=>x.id===t.emp2Id)||{};
  return{nome:t.emp2Nome,cpf:t.cpf||a.cpf||'',empresa:t.empNome,cargo:a.cargo||'',
    treinamento:t.nome,ch:t.cargaHoraria,realizado:t.realizado,validade:t.validade};
}
