function handleDrop(e){e.preventDefault();document.getElementById('drop-area').classList.remove('drag');const f=e.dataTransfer.files[0];if(f)processarXL(f);}
function importarExcel(e){const f=e.target.files[0];if(f)processarXL(f);}
function processarXL(file){
  const reader=new FileReader();
  reader.onload=ev=>{
    try{
      const wb=XLSX.read(ev.target.result,{type:'array'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
      const dados=rows.slice(1).filter(r=>r[0]||r[1]).map(r=>({
        nome:String(r[0]||'').trim().toUpperCase(),
        cpf:String(r[1]||'').trim(),
        empresa:String(r[2]||'').trim().toUpperCase(),
        treinamento:String(r[3]||'').trim().toUpperCase(),
        realizado:r[4]?String(r[4]).trim():'',
        validade:r[5]?String(r[5]).trim():''
      })).filter(r=>r.nome&&r.cpf);
      xlDados=dados;
      const empSet=new Set(dados.map(r=>r.empresa));
      const cpfSet=new Set(dados.map(r=>r.cpf));
      document.getElementById('import-info').innerHTML=`
        <div class="g2">
          <div class="tile"><div class="r">Registros</div><div class="v">${dados.length}</div></div>
          <div class="tile"><div class="r">Empresas</div><div class="v">${empSet.size}</div></div>
          <div class="tile"><div class="r">Empregados únicos</div><div class="v">${cpfSet.size}</div></div>
          <div class="tile"><div class="r">Treinamentos</div><div class="v">${dados.length}</div></div>
        </div>
        <div style="background:#f0fdf4;border-radius:8px;padding:10px;font-size:12px;color:#166534">
          ✅ Arquivo lido com sucesso! Empresas, empregados e treinamentos serão criados automaticamente.
        </div>`;
      document.getElementById('import-preview').style.display='block';
    }catch(e){toast('Erro ao ler o arquivo: '+e.message,true);}
  };
  reader.readAsArrayBuffer(file);
}

async function confirmarImport(){
  if(!xlDados){toast('Nenhum dado para importar.',true);return;}
  const btn=document.getElementById('btn-import-confirmar');
  btn.textContent='⏳ Importando…';btn.disabled=true;
  const{collection,addDoc,serverTimestamp}=window.FS;
  const db=window.db;
  let ok=0,erros=0;
  const empMap={}, emp2Map={};
  try{
    for(const r of xlDados){
      // Empresa
      let empId=empMap[r.empresa];
      if(!empId){
        const ex=empresas.find(e=>e.razaoSocial===r.empresa||e.nomeFantasia===r.empresa);
        if(ex){empId=ex.id;}
        else{const ref=await addDoc(collection(db,'empresas'),{userId:uid(),razaoSocial:r.empresa,nomeFantasia:r.empresa,cnpj:'—',criadoEm:serverTimestamp()});empId=ref.id;}
        empMap[r.empresa]=empId;
      }
      // Empregado
      let emp2Id=emp2Map[r.cpf];
      if(!emp2Id){
        const ex=emp2s.find(a=>a.cpf===r.cpf);
        if(ex){emp2Id=ex.id;}
        else{const ref=await addDoc(collection(db,'emp2s'),{userId:uid(),empId,empNome:r.empresa,nome:r.nome,cpf:r.cpf,cargo:'',criadoEm:serverTimestamp()});emp2Id=ref.id;}
        emp2Map[r.cpf]=emp2Id;
      }
      // Treinamento
      if(r.treinamento){
        await addDoc(collection(db,'treins'),{
          userId:uid(),emp2Id,emp2Nome:r.nome,cpf:r.cpf,empId,empNome:r.empresa,
          nome:r.treinamento,realizado:r.realizado||'',validade:r.validade||'',
          criadoEm:serverTimestamp()
        });ok++;
      }
    }
    toast(`✅ ${ok} treinamentos importados!`);
    xlDados=null;
    document.getElementById('import-preview').style.display='none';
    document.getElementById('xl-input').value='';
    ir('t-dash');
  }catch(e){toast('Erro na importação: '+e.message,true);erros++;}
  btn.textContent='✅ Confirmar Importação';btn.disabled=false;
}
function cancelarImport(){xlDados=null;document.getElementById('import-preview').style.display='none';document.getElementById('xl-input').value='';}

